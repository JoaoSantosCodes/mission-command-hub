# =============================================================================
# Referência — arranque: .env.ready + npm run env:init (cria .env se não existir)
# Servidor e Vite: server/load-env.mjs carrega .env e .env.local
# =============================================================================

# =============================================================================
# Chaves e API (servidor) — colar aqui ou em .env / .env.local
# =============================================================================
# Pelo menos uma chave, ≥8 caracteres, para POST /api/aiox/doubts/chat
# OPENAI_API_KEY=
# MISSION_LLM_API_KEY=
#
# URL e modelo OpenAI-compatible (opcionais; vazio = api.openai.com + gpt-4o-mini)
# MISSION_LLM_BASE_URL=
# MISSION_LLM_MODEL=
#
# MISSION_DOUBTS_LLM=1
# MISSION_DOUBTS_SYSTEM_PROMPT=
# MISSION_DOUBTS_HELP_URL=
# DOUBTS_CHAT_RATE_MAX=20

# =============================================================================
# Hub / processo
# =============================================================================
# AIOX_CORE_PATH=
# PORT=8787
# MISSION_EMBED_API=0
# VITE_APP_VERSION=v1.0.0
# VITE_POLL_INTERVAL_MS=12000

# Persistência (ficheiros por defeito em MissionAgent/.mission-agent/)
# MISSION_ACTIVITY_PATH=
# MISSION_TASK_BOARD_PATH=
# TASK_BOARD_PUT_RATE_MAX=45
# DATABASE_URL=
# PG_POOL_MAX=10

# Canvas: sincronizar com GET/PUT /api/aiox/task-board (rebuild após alterar)
# VITE_TASK_BOARD_SYNC=1

# Rede / segurança
# CORS_ORIGINS=
# TRUST_PROXY=1
# MASK_PATHS_IN_UI=1
# LOG_LEVEL=info
# COMMAND_RATE_MAX=60
# AGENT_EDIT_RATE_MAX=30
# MISSION_AGENT_EDIT=0

# CLI aiox na API (opt-in)
# ENABLE_AIOX_CLI_EXEC=1
# AIOX_EXEC_SECRET=
# AIOX_EXEC_TIMEOUT_MS=120000
# AIOX_EXEC_RATE_MAX=5

# Central / tempo
# WEATHER_LOCATION=Lisboa,Lisboa,Portugal

# Build Vite
# VITE_AIOX_DOCS_URL=

# Outras chaves (não usadas pelo Express por defeito — integrações via MCP no IDE; ver docs/INTEGRATIONS.md)
# ANTHROPIC_API_KEY=
# NOTION_TOKEN=
# FIGMA_ACCESS_TOKEN=
