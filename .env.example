# =============================================================================
# Referência — arranque: .env.ready + npm run env:init (cria .env se não existir)
# Servidor e Vite: server/load-env.mjs carrega .env e .env.local
# =============================================================================

# =============================================================================
# Chaves e API (servidor) — colar aqui ou em .env / .env.local
# =============================================================================
# Chave do fornecedor LLM (qualquer API compatível com /v1/chat/completions). ≥8 caracteres.
# Recomendado: MISSION_LLM_API_KEY=  |  Legado: OPENAI_API_KEY=
# MISSION_LLM_API_KEY=
# OPENAI_API_KEY=
#
# URL e modelo OpenAI-compatible (opcionais; vazio = api.openai.com + gpt-4o-mini)
# MISSION_LLM_BASE_URL=
# MISSION_LLM_MODEL=
# MISSION_LLM_TIMEOUT_MS=60000
# Timeout do POST /api/aiox/doubts/chat/stream (opcional; senão reutiliza o anterior)
# MISSION_LLM_STREAM_TIMEOUT_MS=120000
# MISSION_LLM_MAX_TOKENS=1024
#
# OpenRouter (API compatível com OpenAI): a base NÃO inclui /v1 — o servidor usa {BASE}/v1/chat/completions
# MISSION_LLM_BASE_URL=https://openrouter.ai/api
# MISSION_LLM_MODEL=openai/gpt-4o-mini
# Cabeçalhos opcionais recomendados pela OpenRouter (rankings / identificação da app)
# MISSION_LLM_HTTP_REFERER=http://localhost:5179
# MISSION_LLM_APP_TITLE=Architecture Agents Hub
#
# Verificação local: npm run verify:env (pings opcionais com MISSION_VERIFY_UPSTREAM=1)
# MISSION_VERIFY_UPSTREAM=1
#
# MISSION_DOUBTS_LLM=1
# MISSION_DOUBTS_SYSTEM_PROMPT=
# MISSION_DOUBTS_HELP_URL=
# Sem GET de validação no painel Integrações (útil se o host não expuser /v1/models)
# MISSION_LLM_VALIDATE=0
# Caminho de sondagem GET relativo à base (por defeito v1/models)
# MISSION_LLM_PROBE_PATH=v1/models
# DOUBTS_CHAT_RATE_MAX=20
# Janela do rate limit em ms (10s–1h; por defeito 60_000)
# DOUBTS_CHAT_WINDOW_MS=60000
# Aviso de privacidade no painel Dúvidas (substitui o texto por defeito do servidor)
# MISSION_DOUBTS_DATA_NOTICE=
# URL para página de política de dados (link na UI)
# MISSION_DOUBTS_DATA_POLICY_URL=

# =============================================================================
# Ambiente real (servidor / produção)
# =============================================================================
# npm run build && NODE_ENV=production npm run verify:real
# MISSION_PREFLIGHT_SKIP_AIOX=1  (só CI / contentores sem clone aiox)
#
# =============================================================================
# Hub / processo
# =============================================================================
# Raiz do projeto AIOX (pasta com .aiox-core). Por defeito: MissionAgent (usa ./.aiox-core)
# AIOX_CORE_PATH=
# (Opcional) Pasta absoluta dos .md dos agentes — ignora agents_dir nos YAML
# AIOX_AGENTS_DIR=
# PORT=8787
# Em `npm run dev` a API já vem embebida no Vite. Usa `MISSION_EMBED_API=0` só em `npm run dev:split` / preview com proxy para Express.
# MISSION_EMBED_API=0
# VITE_APP_VERSION=v1.0.0
# VITE_POLL_INTERVAL_MS=12000

# Persistência (ficheiros por defeito em MissionAgent/.mission-agent/)
# MISSION_ACTIVITY_PATH=
# MISSION_TASK_BOARD_PATH=
# MISSION_TASK_RUNS_PATH=
# MISSION_CUSTOMIZATION_PATH=
# MISSION_FISH_PATH=
# MISSION_INTEGRATIONS_HISTORY_PATH=
# TASK_BOARD_PUT_RATE_MAX=45
# MISSION_TASK_AUTORUN=1
# MISSION_TASK_AUTORUN_POLL_MS=5500
# MISSION_TASK_AGENT_ALLOWLIST=*:agentStep
# DATABASE_URL=
# PG_POOL_MAX=10

# Canvas: sincronizar com GET/PUT /api/aiox/task-board (rebuild após alterar)
# VITE_TASK_BOARD_SYNC=1

# Rede / segurança
# CORS_ORIGINS=
# TRUST_PROXY=1
# MASK_PATHS_IN_UI=1
# LOG_LEVEL=info
# COMMAND_RATE_MAX=60
# AGENT_EDIT_RATE_MAX=30
# MISSION_AGENT_EDIT=0

# CLI aiox na API (opt-in)
# ENABLE_AIOX_CLI_EXEC=1
# AIOX_EXEC_SECRET=
# AIOX_EXEC_TIMEOUT_MS=120000
# AIOX_EXEC_RATE_MAX=5

# Central / tempo
# WEATHER_LOCATION=Lisboa,Lisboa,Portugal

# Build Vite
# VITE_AIOX_DOCS_URL=

# Outras chaves (não usadas pelo Express por defeito — integrações via MCP no IDE; ver docs/INTEGRATIONS.md)
# ANTHROPIC_API_KEY=
# NOTION_TOKEN=
# FIGMA_ACCESS_TOKEN=
# MISSION_INTEGRATIONS_TIMEOUT_MS=7000
#
# Slack — espelhar feed da equipa no canal (Incoming Webhook)
# https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# SLACK_WEBHOOK_TIMEOUT_MS=8000
