# =============================================================================
# Referência completa — para arranque rápido usa o ficheiro versionado .env.ready
# e:  npm run env:init   (cria .env se não existir; depois edita OPENAI_API_KEY)
# O servidor e o Vite carregam .env e .env.local automaticamente (server/load-env.mjs).
# =============================================================================

# Caminho para a raiz do repositório aiox-core (opcional)
# AIOX_CORE_PATH=D:\caminho\para\aiox-core

# Porta da API Express (por defeito 8787)
# PORT=8787

# npm run dev / preview: não embeber a ponte Express no Vite — /api passa a usar proxy → :8787 (corre `node server/index.mjs` ou dev:split)
# MISSION_EMBED_API=0

# Versão mostrada no header (opcional)
# VITE_APP_VERSION=v1.0.0

# Intervalo de polling da UI (ms; mín. 5000, por defeito 12000)
# VITE_POLL_INTERVAL_MS=12000

# Ficheiro JSON do feed de atividade (opcional; por defeito: MissionAgent/.mission-agent/activity.json)
# MISSION_ACTIVITY_PATH=D:\caminho\activity.json

# Quadro Kanban (Canvas) no servidor — GET/PUT /api/aiox/task-board (por defeito: MissionAgent/.mission-agent/task-board.json)
# MISSION_TASK_BOARD_PATH=D:\caminho\task-board.json
# Máximo de PUT /api/aiox/task-board por IP/min (por defeito 45)
# TASK_BOARD_PUT_RATE_MAX=45

# No cliente (rebuild): sincronizar o Canvas com a API (ficheiro no servidor). Requer a mesma origem que /api (npm run dev / preview / start)
# VITE_TASK_BOARD_SYNC=1

# PostgreSQL opcional: quando definido, o feed de atividade usa a tabela mission_activity_log (fallback para JSON se falhar)
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/mission_agent
# Tamanho máximo do pool (opcional; por defeito 10)
# PG_POOL_MAX=10

# Origens CORS permitidas em produção (lista separada por vírgulas). Vazio = reflecte qualquer origem (dev).
# CORS_ORIGINS=http://127.0.0.1:5179,http://localhost:5179

# Máximo de POST /api/aiox/command por IP por minuto (por defeito 60)
# COMMAND_RATE_MAX=60

# Confia no primeiro proxy (X-Forwarded-*) — usar atrás de reverse proxy
# TRUST_PROXY=1

# Nível de log do servidor (pino): trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Ocultar caminhos absolutos na API / UI (mostra só …/último-segmento)
# MASK_PATHS_IN_UI=1

# Executar na API os subcomandos aiox doctor | info (opt-in; usar só em rede de confiança)
# ENABLE_AIOX_CLI_EXEC=1
# AIOX_EXEC_SECRET=coloca_um_segredo_longo_aqui
# Tempo máximo por execução (ms, máx. 600000)
# AIOX_EXEC_TIMEOUT_MS=120000
# Máximo de POST /api/aiox/exec por IP por minuto
# AIOX_EXEC_RATE_MAX=5

# Localização para o widget de tempo na central de agentes (wttr.in)
# WEATHER_LOCATION=Lisboa,Lisboa,Portugal

# Criar / gravar / eliminar definições de agentes (.md) via API / UI (por defeito activo). 0 = só leitura
# MISSION_AGENT_EDIT=0
# Máximo de PUT /api/aiox/agents/:id por IP por minuto (por defeito 30)
# AGENT_EDIT_RATE_MAX=30

# URL opcional mostrada no painel Dúvidas quando a API responde (GET /api/aiox/doubts → docsUrl)
# MISSION_DOUBTS_HELP_URL=https://example.com/ajuda

# --- LLM no painel Dúvidas (opt-in; servidor só — nunca no bundle Vite) ---
# 1 = activa POST /api/aiox/doubts/chat (API OpenAI-compatible em MISSION_LLM_BASE_URL ou OPENAI_BASE_URL)
# MISSION_DOUBTS_LLM=1
# OPENAI_API_KEY=sk-...
# ou MISSION_LLM_API_KEY=... (alternativa ao nome OpenAI)
# MISSION_LLM_BASE_URL=https://api.openai.com
# MISSION_LLM_MODEL=gpt-4o-mini
# MISSION_LLM_TIMEOUT_MS=60000
# MISSION_LLM_MAX_TOKENS=1024
# Prompt de sistema (opcional; senão usa texto por defeito em server/lib/doubts-llm.mjs)
# MISSION_DOUBTS_SYSTEM_PROMPT=Este assistente ajuda no Architecture Agents Hub...
# Máximo de POST /api/aiox/doubts/chat por IP por minuto (por defeito 20)
# DOUBTS_CHAT_RATE_MAX=20

# --- Integrações (opcional; o hub não usa estes valores por defeito — ver docs/INTEGRATIONS.md) ---
# LLM / APIs externas só se no futuro existir camada server-side no Express (nunca expor chaves no bundle Vite)
# ANTHROPIC_API_KEY=
# NOTION_TOKEN=          # preferir MCP Notion no Cursor em vez de variável no Mission Agent
# FIGMA_ACCESS_TOKEN=    # idem para MCP Figma

# --- apenas build Vite (prefixo VITE_) ---
# URL da documentação aiox-core aberta na área de trabalho
# VITE_AIOX_DOCS_URL=https://example.com/docs
