# Caminho para a raiz do repositório aiox-core (opcional)
# AIOX_CORE_PATH=D:\caminho\para\aiox-core

# Porta da API Express (por defeito 8787)
# PORT=8787

# Versão mostrada no header (opcional)
# VITE_APP_VERSION=v1.0.0

# Intervalo de polling da UI (ms; mín. 5000, por defeito 12000)
# VITE_POLL_INTERVAL_MS=12000

# Ficheiro JSON do feed de atividade (opcional; por defeito: MissionAgent/.mission-agent/activity.json)
# MISSION_ACTIVITY_PATH=D:\caminho\activity.json

# PostgreSQL opcional: quando definido, o feed de atividade usa a tabela mission_activity_log (fallback para JSON se falhar)
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/mission_agent
# Tamanho máximo do pool (opcional; por defeito 10)
# PG_POOL_MAX=10

# Origens CORS permitidas em produção (lista separada por vírgulas). Vazio = reflecte qualquer origem (dev).
# CORS_ORIGINS=http://127.0.0.1:5179,http://localhost:5179

# Máximo de POST /api/aiox/command por IP por minuto (por defeito 60)
# COMMAND_RATE_MAX=60

# Confia no primeiro proxy (X-Forwarded-*) — usar atrás de reverse proxy
# TRUST_PROXY=1

# Nível de log do servidor (pino): trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Ocultar caminhos absolutos na API / UI (mostra só …/último-segmento)
# MASK_PATHS_IN_UI=1

# Executar na API os subcomandos aiox doctor | info (opt-in; usar só em rede de confiança)
# ENABLE_AIOX_CLI_EXEC=1
# AIOX_EXEC_SECRET=coloca_um_segredo_longo_aqui
# Tempo máximo por execução (ms, máx. 600000)
# AIOX_EXEC_TIMEOUT_MS=120000
# Máximo de POST /api/aiox/exec por IP por minuto
# AIOX_EXEC_RATE_MAX=5

# Localização para o widget de tempo na central de agentes (wttr.in)
# WEATHER_LOCATION=Lisboa,Lisboa,Portugal

# Gravar definições de agentes (.md) via API / UI (por defeito activo). Definir 0 para só leitura
# MISSION_AGENT_EDIT=0
# Máximo de PUT /api/aiox/agents/:id por IP por minuto (por defeito 30)
# AGENT_EDIT_RATE_MAX=30

# --- apenas build Vite (prefixo VITE_) ---
# URL da documentação aiox-core aberta na área de trabalho
# VITE_AIOX_DOCS_URL=https://example.com/docs
