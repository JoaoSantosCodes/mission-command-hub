{
  "name": "mission-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Architecture Agents Hub — UI + ponte ao aiox-core local",
  "scripts": {
    "env:init": "node scripts/init-env.mjs",
    "predev": "node scripts/init-env.mjs",
    "prepreview": "node scripts/init-env.mjs",
    "prestart": "node scripts/init-env.mjs",
    "dev": "vite --config vite.config.ts",
    "dev:split": "concurrently -k -n api,web -c blue,magenta \"node server/index.mjs\" \"vite --config vite.config.ts\"",
    "build": "tsc -p tsconfig.json --noEmit && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts --host",
    "preview:all": "concurrently -k -n api,ui -c blue,green \"node server/index.mjs\" \"vite preview --config vite.config.ts --host\"",
    "start": "cross-env NODE_ENV=production node server/index.mjs",
    "mcp": "node server/mcp-server.mjs",
    "test": "vitest run",
    "verify:env": "node scripts/verify-real-env.mjs",
    "verify:real": "node scripts/preflight-real-env.mjs",
    "postinstall": "node scripts/init-env.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.462.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
