# =============================================================================
# Architecture Agents Hub — ambiente local (template só para chave + API)
# =============================================================================
# `npm run env:init` copia isto para `.env` (se ainda não existir).
# Depois edita `.env` e preenche pelo menos UMA chave abaixo (mín. 8 caracteres).
# URL e modelo são opcionais — se ficarem vazios, o servidor usa API OpenAI por defeito.
# =============================================================================

PORT=8787
VITE_POLL_INTERVAL_MS=12000

# --- Painel Dúvidas: POST /api/aiox/doubts/chat (chave só no servidor) ---
MISSION_DOUBTS_LLM=1

# Chave OpenAI-compatible (obrigatória para o chat LLM). Alternativa: MISSION_LLM_API_KEY=
OPENAI_API_KEY=
MISSION_LLM_API_KEY=

# URL base da API (opcional; vazio = https://api.openai.com)
MISSION_LLM_BASE_URL=

# Modelo (opcional; vazio = gpt-4o-mini no servidor)
MISSION_LLM_MODEL=

# --- Opcional ---
# MISSION_LLM_TIMEOUT_MS=60000
# MISSION_LLM_MAX_TOKENS=1024
# DOUBTS_CHAT_RATE_MAX=20
# MISSION_DOUBTS_HELP_URL=
# AIOX_CORE_PATH=
# MISSION_EMBED_API=0
#
# --- Ambiente real / produção (recomendado em .env.local no servidor) ---
# NODE_ENV=production
# CORS_ORIGINS=https://o-teu-dominio.com
# TRUST_PROXY=1
# MASK_PATHS_IN_UI=1
# MISSION_AGENT_EDIT=0
# DATABASE_URL=postgresql://...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
#
# Segredos da equipa: preferir .env.local (sobrescreve .env; não commitar).
# Antes de npm start: npm run build && NODE_ENV=production npm run verify:real
