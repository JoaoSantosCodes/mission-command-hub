# =============================================================================
# Architecture Agents Hub — ambiente local pré-configurado
# =============================================================================
# Este ficheiro é a base para `npm run env:init` → cria `.env` (não versionado).
# Depois de criar `.env`, edita e coloca a tua chave OpenAI-compatible em
# OPENAI_API_KEY (mínimo 8 caracteres). Com MISSION_DOUBTS_LLM=1, o painel
# Dúvidas passa a usar POST /api/aiox/doubts/chat automaticamente.
# =============================================================================

PORT=8787
VITE_POLL_INTERVAL_MS=12000

# --- Painel Dúvidas + LLM (aguarda chave) ---
MISSION_DOUBTS_LLM=1
OPENAI_API_KEY=
MISSION_LLM_BASE_URL=https://api.openai.com
MISSION_LLM_MODEL=gpt-4o-mini
MISSION_LLM_TIMEOUT_MS=60000
MISSION_LLM_MAX_TOKENS=1024
DOUBTS_CHAT_RATE_MAX=20

# --- Opcional: ajuda externa no painel (GET /api/aiox/doubts → docsUrl) ---
# MISSION_DOUBTS_HELP_URL=

# --- aiox-core (por defeito procura ../aiox-core relativo a MissionAgent) ---
# AIOX_CORE_PATH=

# --- API embebida no Vite (dev/preview). 0 = só proxy → :8787 ---
# MISSION_EMBED_API=0
